VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Cloudflare R2 report storage (via workers/r2-reports)
# Must be set at BUILD time (Vite embeds them). For GitHub Pages, add as repo Secrets:
#   VITE_R2_API_URL, VITE_R2_API_TOKEN (same token as worker secret R2_API_TOKEN)
VITE_R2_API_URL=https://physio-r2-reports.your-subdomain.workers.dev
VITE_R2_API_TOKEN=your-shared-api-token
